{
  "name": "@chittyos/chittymcp",
  "version": "1.0.0",
  "description": "Consolidated Model Context Protocol servers for the ChittyOS ecosystem",
  "type": "module",
  "main": "src/servers/unified-server.js",
  "bin": {
    "chittymcp": "./src/servers/unified-server.js",
    "chittymcp-evidence": "./src/servers/evidence-server.js"
  },
  "scripts": {
    "start": "node src/servers/unified-server.js",
    "start:evidence": "node src/servers/evidence-server.js",
    "dev": "nodemon src/servers/unified-server.js",
    "dev:evidence": "nodemon src/servers/evidence-server.js",
    "test": "node --test test/governance-gates.test.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "deploy:prod": "wrangler deploy --config wrangler.jsonc --env production"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "chittyos",
    "legal-tech",
    "cloudflare",
    "ai"
  ],
  "author": "ChittyOS Framework",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "agents": "^0.17.3",
    "chokidar": "^5.0.0",
    "crypto": "^1.0.1",
    "fs-extra": "^11.3.6",
    "jose": "^6.2.3",
    "node-fetch": "^3.3.2",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260621.1",
    "eslint": "^10.7.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "wrangler": "^4.110.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/chittyos/chittymcp.git"
  }
}
